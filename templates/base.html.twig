<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block meta_title %}{{ meta_title ?? 'ColocChaleureuse' }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ meta_desc ?? 'Gestion éco-conçue de colocation.'|trans }}{% endblock %}">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="{% block og_title %}{{ meta_title ?? 'ColocChaleureuse' }}{% endblock %}">
    <meta property="og:type" content="website">
    <link rel="canonical" href="{{ app.request.uri }}">

    <style>
        :root {
            --primary: #ffaa00;
            --dark-brown: #553900;
            --gold: #aa7100;
            --bg-light: #fffdf9;
            --green: #2d7a2d;
            --red: #b32424;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-light);
            color: var(--dark-brown);
            margin: 0; padding: 0; line-height: 1.6;
        }
        .skip-link {
            position: absolute; top: -40px; left: 0;
            background: var(--primary); color: var(--dark-brown);
            padding: 8px; z-index: 100; transition: top 0.2s;
        }
        .skip-link:focus { top: 0; }
        header {
            background-color: var(--primary);
            padding: 1rem; border-bottom: 4px solid var(--gold);
        }
        nav ul {
            display: flex; list-style: none; margin: 0; padding: 0;
            gap: 1.2rem; flex-wrap: wrap; align-items: center;
        }
        nav a { color: var(--dark-brown); text-decoration: none; font-weight: bold; }
        nav a:hover, nav a:focus { text-decoration: underline; outline: 2px solid var(--dark-brown); }
        main { padding: 2rem; max-width: 1200px; margin: 0 auto; }
        footer {
            background-color: var(--dark-brown); color: white;
            text-align: center; padding: 1rem;
            margin-top: 4rem; font-size: 0.9rem;
        }
        .btn {
            background-color: var(--primary); color: var(--dark-brown);
            padding: 0.6rem 1.2rem; border: 2px solid var(--gold);
            border-radius: 8px; cursor: pointer; text-decoration: none;
            display: inline-block; font-weight: bold;
        }
        .btn-danger { background: var(--red); color: white; border-color: var(--red); }
        .btn-secondary { background: white; }
        .flash { padding: 0.9rem 1rem; margin-bottom: 1rem; border-radius: 6px; border: 1px solid; }
        .flash-success { background: #e6ffed; color: var(--green); border-color: var(--green); }
        .flash-error   { background: #fff0f0; color: var(--red); border-color: var(--red); }
        .flash-info    { background: #fffbe6; color: var(--gold); border-color: var(--gold); }
        .card { background: white; border: 2px solid var(--gold); border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th, td { padding: 10px; border: 1px solid var(--gold); text-align: left; }
        thead tr { background: var(--primary); color: var(--dark-brown); }
        form .field { margin-bottom: 1rem; }
        form label { display: block; font-weight: bold; margin-bottom: 0.3rem; }
        form input, form select, form textarea {
            width: 100%; padding: 8px; border: 1px solid var(--gold); border-radius: 4px;
            font-family: inherit; font-size: 1rem;
        }
        .lang-switch a { margin-left: 0.4rem; padding: 2px 6px; border: 1px solid var(--dark-brown); border-radius: 3px; font-size: 0.85rem; }
        .lang-switch a.active { background: var(--dark-brown); color: var(--primary); }
    </style>
</head>
<body>
<a href="#main-content" class="skip-link">{{ 'a11y.skip'|trans }}</a>
<header role="banner">
    <nav role="navigation" aria-label="{{ 'nav.main'|trans }}">
        <ul>
            <li><a href="{{ path('app_home') }}">{{ 'nav.home'|trans }}</a></li>
            {% if is_granted('ROLE_USER') %}
                <li><a href="{{ path('app_chores') }}">{{ 'nav.chores'|trans }}</a></li>
                <li><a href="{{ path('app_messages') }}">{{ 'nav.messages'|trans }}</a></li>
            {% endif %}
            {% if is_granted('ROLE_TENANT') %}
                <li><a href="{{ path('app_tenant_dashboard') }}">{{ 'nav.tenant_space'|trans }}</a></li>
            {% endif %}
            {% if is_granted('ROLE_OWNER') %}
                <li><a href="{{ path('app_owner_dashboard') }}">{{ 'nav.owner_space'|trans }}</a></li>
            {% endif %}
            {% if is_granted('ROLE_USER') %}
                <li><a href="{{ path('app_change_password') }}">{{ 'nav.account'|trans }}</a></li>
            {% endif %}
            <li>
                {% if app.user %}
                    <a href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn">{{ 'nav.login'|trans }}</a>
                    <a href="{{ path('app_register') }}" class="btn btn-secondary">{{ 'nav.register'|trans }}</a>
                {% endif %}
            </li>
            <li class="lang-switch" aria-label="{{ 'nav.language'|trans }}">
                {% set route_params = app.request.attributes.get('_route_params')|default({})|merge(app.request.query.all) %}
                {% for locale in ['fr', 'en'] %}
                    <a href="{{ path(app.request.attributes.get('_route'), route_params|merge({'_locale': locale})) }}"
                       class="{{ app.request.locale == locale ? 'active' : '' }}"
                       hreflang="{{ locale }}" rel="alternate">{{ locale|upper }}</a>
                {% endfor %}
            </li>
        </ul>
    </nav>
</header>

<main id="main-content" role="main">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}" role="alert">{{ message|trans }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer>
    <p>&copy; 2026 ColocChaleureuse. {{ 'footer.greenit'|trans }}</p>
</footer>
</body>
</html>
