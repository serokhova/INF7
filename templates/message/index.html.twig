{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ 'msg.title'|trans }} 💬</h1>

{% if household is null %}
    <div class="card"><p>{{ 'msg.no_house'|trans }}</p></div>
{% else %}
    <p>{{ 'msg.intro'|trans({'%name%': household.name}) }}</p>

    <div class="card">
        <h2>{{ 'msg.new'|trans }}</h2>
        {{ form_start(form) }}
            <div class="field">{{ form_row(form.content) }}</div>
            <button class="btn" type="submit">{{ 'msg.send'|trans }}</button>
        {{ form_end(form) }}
    </div>

    <h2>{{ 'msg.feed'|trans }}</h2>
    {% if messages|length == 0 %}
        <p>{{ 'msg.empty'|trans }}</p>
    {% else %}
        {% for m in messages %}
            <article class="card" style="padding: 0.8rem;">
                <p style="margin: 0 0 0.4rem 0;">
                    <strong>{{ m.author.fullName }}</strong>
                    <span style="color: gray; font-size: 0.85rem;">— {{ m.createdAt|date('d/m/Y H:i') }}</span>
                </p>
                <p style="margin: 0; white-space: pre-wrap;">{{ m.content }}</p>
            </article>
        {% endfor %}
    {% endif %}
{% endif %}
{% endblock %}
