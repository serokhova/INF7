{% extends 'base.html.twig' %}

{% block body %}
<h1>Mon Tableau de Bord Locataire 👋</h1>
<p>Ravi de vous revoir, {{ user.firstName }} ! Voici le récapitulatif de votre colocation.</p>

<div style="background: white; border: 2px solid var(--primary); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
    <h3>🏠 Ma Colocation : {{ household.name ?? 'Non assignée' }}</h3>
    <p><strong>Adresse :</strong> {{ household.address ?? 'N/A' }}</p>
    <p><strong>Votre répartition (Tantième) :</strong> {{ tantieme }}% des charges globales</p>
</div>

<h2>Historique de vos Paiements</h2>
<table style="width: 100%; border-collapse: collapse; background: white;">
    <thead>
        <tr style="background: var(--primary); color: var(--dark-brown);">
            <th style="padding: 10px; text-align: left; border: 1px solid var(--gold);">Date</th>
            <th style="padding: 10px; text-align: left; border: 1px solid var(--gold);">Type</th>
            <th style="padding: 10px; text-align: left; border: 1px solid var(--gold);">Montant</th>
            <th style="padding: 10px; text-align: left; border: 1px solid var(--gold);">État</th>
        </tr>
    </thead>
    <tbody>
        {% for payment in payments %}
        <tr>
            <td style="padding: 10px; border: 1px solid var(--gold);">{{ payment.date }}</td>
            <td style="padding: 10px; border: 1px solid var(--gold);">{{ payment.type }}</td>
            <td style="padding: 10px; border: 1px solid var(--gold);">{{ payment.amount }} €</td>
            <td style="padding: 10px; border: 1px solid var(--gold);"><span style="color: green; font-weight: bold;">✔ {{ payment.status }}</span></td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
