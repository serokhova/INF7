{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ 'tenant.dashboard_title'|trans }} 👋</h1>
<p>{{ 'tenant.welcome'|trans({'%name%': user.firstName}) }}</p>

<div class="card">
    <h3>🏠 {{ 'tenant.my_house'|trans }} : {{ household ? household.name : 'tenant.no_house'|trans }}</h3>
    {% if household %}
        <p><strong>{{ 'tenant.address'|trans }} :</strong> {{ household.address }}</p>
        <p><strong>{{ 'tenant.tantieme'|trans }} :</strong> {{ tantieme }}%</p>
        <p><strong>{{ 'tenant.my_rent'|trans }} :</strong> {{ user.monthlyRent ?? '—' }} €</p>
    {% endif %}
</div>

{% if household %}
<div class="card">
    <h2>{{ 'tenant.current_period'|trans({'%period%': period}) }}</h2>
    <p><strong>{{ 'tenant.total_charges_house'|trans }} :</strong> {{ total_charges|number_format(2, ',', ' ') }} €</p>
    <p><strong>{{ 'tenant.your_share'|trans }} ({{ tantieme }}%):</strong>
        <span style="font-size: 1.4rem; color: var(--red); font-weight: bold;">{{ user_share|number_format(2, ',', ' ') }} €</span>
    </p>
    {% if expenses_by_category|length > 0 %}
        <ul>
            {% for cat, amount in expenses_by_category %}
                <li>{{ ('expense.' ~ cat)|trans }} : {{ amount|number_format(2, ',', ' ') }} €</li>
            {% endfor %}
        </ul>
    {% endif %}
    <a href="{{ path('app_tenant_pay') }}" class="btn">{{ 'tenant.pay_btn'|trans }}</a>
</div>

<h2>{{ 'tenant.payment_history'|trans }}</h2>
{% if payments|length == 0 %}
    <p>{{ 'tenant.no_payments'|trans }}</p>
{% else %}
<table>
    <thead>
        <tr>
            <th>{{ 'tenant.period'|trans }}</th>
            <th>{{ 'tenant.rent'|trans }}</th>
            <th>{{ 'tenant.charges'|trans }}</th>
            <th>{{ 'tenant.total'|trans }}</th>
            <th>{{ 'tenant.status'|trans }}</th>
            <th>{{ 'tenant.receipt'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        {% for p in payments %}
        <tr>
            <td>{{ p.period }}</td>
            <td>{{ p.rentAmount }} €</td>
            <td>{{ p.chargesAmount }} €</td>
            <td><strong>{{ p.totalAmount }} €</strong></td>
            <td>
                {% if p.status == 'paid' %}<span style="color: var(--green); font-weight: bold;">✔ {{ 'status.paid'|trans }}</span>
                {% elseif p.status == 'late' %}<span style="color: var(--red); font-weight: bold;">⚠ {{ 'status.late'|trans }}</span>
                {% else %}<span>{{ 'status.pending'|trans }}</span>{% endif %}
            </td>
            <td><a href="{{ path('app_tenant_receipt', {'id': p.id}) }}">{{ 'tenant.view'|trans }}</a></td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}
{% endif %}
{% endblock %}
