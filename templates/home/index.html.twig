{% extends 'base.html.twig' %}

{% block body %}
<section style="text-align: center; padding: 2rem 0;">
    <h1>{{ 'home.welcome'|trans }}</h1>
    <p style="font-size: 1.2rem; max-width: 600px; margin: 1rem auto;">
        Gérer sa colocation n'a jamais été aussi simple, léger et convivial. Finies les prises de tête pour la vaisselle ou les comptes !
    </p>
    <a href="{{ path('app_login') }}" class="btn" style="font-size: 1.1rem; padding: 0.8rem 2rem;">{{ 'home.cta'|trans }}</a>
</section>

<hr style="border: 0; border-top: 2px solid var(--primary); margin: 3rem 0;">

<section id="faq">
    <h2>Foire Aux Questions (FAQ)</h2>
    {% for faq in faqs %}
        <details style="background: #fff; border: 1px solid var(--gold); padding: 1rem; margin-bottom: 1rem; border-radius: 6px;">
            <summary style="font-weight: bold; cursor: pointer; color: var(--gold);">{{ faq.q|trans }}</summary>
            <p style="margin-top: 0.5rem; margin-left: 1rem;">{{ faq.a|trans }}</p>
        </details>
    {% endfor %}
</section>
{% endblock %}
