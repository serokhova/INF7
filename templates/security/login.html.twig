{% extends 'base.html.twig' %}

{% block body %}
<div class="card" style="max-width: 420px; margin: 3rem auto;">
    <h1>{{ 'security.login_title'|trans }}</h1>

    <form method="post">
        {% if error %}
            <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <div class="field">
            <label for="inputEmail">{{ 'form.email'|trans }}</label>
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" autocomplete="email" required autofocus>
        </div>

        <div class="field">
            <label for="inputPassword">{{ 'form.password'|trans }}</label>
            <input type="password" name="_password" id="inputPassword" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button class="btn" style="width: 100%; font-size: 1.1rem;" type="submit">{{ 'security.login_btn'|trans }}</button>
    </form>

    <p style="margin-top: 1rem; text-align: center;">
        <a href="{{ path('app_forgot_password') }}">{{ 'security.forgot_link'|trans }}</a>
        &middot;
        <a href="{{ path('app_register') }}">{{ 'security.register_link'|trans }}</a>
    </p>
</div>
{% endblock %}
