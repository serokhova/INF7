{% extends 'base.html.twig' %}

{% block body %}
<div class="card" style="max-width: 460px; margin: 2rem auto;">
    <h1>{{ 'security.forgot_title'|trans }}</h1>
    <p>{{ 'security.forgot_intro'|trans }}</p>

    {{ form_start(form) }}
        <div class="field">{{ form_row(form.email) }}</div>
        <button class="btn" type="submit" style="width: 100%;">{{ 'security.forgot_btn'|trans }}</button>
    {{ form_end(form) }}

    {% if reset_link %}
        <div class="flash flash-info" style="margin-top: 1.5rem;">
            <strong>{{ 'security.dev_link'|trans }}</strong><br>
            <a href="{{ reset_link }}">{{ reset_link }}</a>
        </div>
    {% endif %}
</div>
{% endblock %}
