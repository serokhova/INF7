{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ 'owner.tenants_title'|trans }} — {{ household.name }}</h1>
<a href="{{ path('app_owner_dashboard') }}">&larr; {{ 'owner.back'|trans }}</a>

<form method="post" class="card" style="margin-top: 1rem;">
    <input type="hidden" name="_token" value="{{ csrf_token('manage-tenants-' ~ household.id) }}">

    <h2>{{ 'owner.house_settings'|trans }}</h2>
    <div class="field">
        <label for="monthly_charges">{{ 'owner.monthly_charges'|trans }} (€)</label>
        <input type="number" step="0.01" min="0" id="monthly_charges" name="monthly_charges" value="{{ household.monthlyCharges }}">
    </div>

    <h2>{{ 'owner.tenants_settings'|trans }}</h2>
    {% if household.tenants|length == 0 %}
        <p>{{ 'owner.no_tenants'|trans }}</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th>{{ 'owner.tenant'|trans }}</th>
                <th>{{ 'tenant.tantieme'|trans }} (%)</th>
                <th>{{ 'tenant.my_rent'|trans }} (€)</th>
            </tr>
        </thead>
        <tbody>
        {% for t in household.tenants %}
            <tr>
                <td>{{ t.fullName }} ({{ t.email }})</td>
                <td><input type="number" step="0.01" min="0" max="100" name="tantieme_{{ t.id }}" value="{{ t.tantieme ?? '0' }}"></td>
                <td><input type="number" step="0.01" min="0" name="rent_{{ t.id }}" value="{{ t.monthlyRent ?? '0' }}"></td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <button class="btn" type="submit" style="margin-top: 1rem;">{{ 'form.update'|trans }}</button>
</form>
{% endblock %}
